---
const { title = 'Isaac Greenwald', active = '' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&display=swap"
      rel="stylesheet"
    />
  </head>
  <body>
    <header class="topbar">
      <a class="wordmark" href="/">Isaac Greenwald</a>
      <nav class="nav">
        <a href="/photography" class:list={{ active: active === 'color' }}>Color</a>
        <a href="/photography/digital" class:list={{ active: active === 'digital' }}>Digital</a>
        <a href="/photography/35mm" class:list={{ active: active === '35mm' }}>35mm</a>
      </nav>
    </header>

    <slot />

    <style is:global>
      :root {
        --font-sans: 'Inter', system-ui, sans-serif;
        --font-serif: 'Newsreader', Georgia, serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: var(--font-sans);
        background: #0a0a0a;
        color: #e0e0e0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }
      a, a:link, a:visited { color: inherit; text-decoration: none; }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem 2.25rem;
      }
      .wordmark {
        font-family: var(--font-sans);
        font-size: 0.95rem;
        font-weight: 400;
        text-transform: uppercase;
        letter-spacing: 0.13em;
        white-space: nowrap;
        opacity: 0.55;
        transition: opacity 0.2s ease;
      }
      .wordmark:hover { opacity: 1; }
      .nav {
        display: flex;
        gap: 1.75rem;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
      }
      .nav a {
        opacity: 0.4;
        transition: opacity 0.2s ease;
      }
      .nav a:hover, .nav a.active { opacity: 1; }
    </style>
  </body>
</html>
