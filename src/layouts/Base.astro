---
const { title = 'Isaac Greenwald' } = Astro.props;
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>{title}</title>
  </head>
  <body>
    <slot />
    <style is:global>
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: system-ui, sans-serif;
        background: #0a0a0a;
        color: #e0e0e0;
        min-height: 100vh;
      }
      a { color: inherit; }
    </style>
  </body>
</html>
