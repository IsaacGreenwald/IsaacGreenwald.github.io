---
import PhotoLayout from '../layouts/PhotoLayout.astro';
import ColorBarcode from '../components/ColorBarcode.jsx';
import photos from '../data/photos.json';
---

<PhotoLayout title="Photography - Isaac Greenwald" active="color">
  <main class="hero">
    <div class="hero-intro">
      <h1>Every frame, by color.</h1>
    </div>

    <ColorBarcode client:load photos={photos} />
  </main>

  <style>
    .hero {
      flex: 1;
      display: flex;
      flex-direction: column;
      align-items: center;
      text-align: center;
      padding: 2rem;
    }
    .hero-intro {
      max-width: 38rem;
      margin: clamp(2rem, 9vh, 6rem) auto 3.5rem;
    }
    .hero h1 {
      font-family: var(--font-serif);
      font-size: clamp(2.25rem, 5vw, 3.5rem);
      font-weight: 500;
      line-height: 1.05;
    }
  </style>
</PhotoLayout>
