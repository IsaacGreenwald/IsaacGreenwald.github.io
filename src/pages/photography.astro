---
import ColorBarcode from '../components/ColorBarcode.jsx';
import photos from '../data/photos.json';
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Photography — Isaac Greenwald</title>
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500&family=Newsreader:ital,opsz,wght@0,6..72,400;0,6..72,500;1,6..72,400&display=swap"
      rel="stylesheet"
    />
    <style>
      :root {
        --font-sans: 'Inter', system-ui, sans-serif;
        --font-serif: 'Newsreader', Georgia, serif;
      }
      * { box-sizing: border-box; margin: 0; padding: 0; }
      body {
        font-family: var(--font-sans);
        background: #0a0a0a;
        color: #e0e0e0;
        min-height: 100vh;
        display: flex;
        flex-direction: column;
      }

      .topbar {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 1.5rem 2.25rem;
      }
      .wordmark {
        font-family: var(--font-serif);
        font-size: 1.05rem;
        letter-spacing: 0.01em;
        text-decoration: none;
        color: inherit;
      }
      .nav {
        display: flex;
        gap: 1.75rem;
        font-size: 0.7rem;
        text-transform: uppercase;
        letter-spacing: 0.18em;
      }
      .nav a {
        color: inherit;
        text-decoration: none;
        opacity: 0.5;
        transition: opacity 0.2s ease;
      }
      .nav a:hover, .nav a.active { opacity: 1; }

      .hero {
        flex: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        text-align: center;
        padding: 2rem;
      }
      .hero-intro {
        max-width: 38rem;
        margin: clamp(2rem, 9vh, 6rem) auto 3.5rem;
      }
      .hero h1 {
        font-family: var(--font-serif);
        font-size: clamp(2.25rem, 5vw, 3.5rem);
        font-weight: 500;
        line-height: 1.05;
      }
      .lede {
        margin-top: 1.25rem;
        font-size: 0.95rem;
        line-height: 1.6;
        color: #9a9a9a;
      }
      .lede em {
        font-family: var(--font-serif);
        font-style: italic;
        color: #cfcfcf;
      }
    </style>
    <style is:global>
      a, a:link, a:visited { color: inherit; text-decoration: none; }
    </style>
  </head>
  <body>
    <header class="topbar">
      <a class="wordmark" href="/">Isaac Greenwald</a>
      <nav class="nav">
        <a href="/photography" class="active">Color</a>
        <a href="/photography/digital">Digital</a>
        <a href="/photography/35mm">35mm</a>
      </nav>
    </header>

    <main class="hero">
      <div class="hero-intro">
        <h1>Every frame, by color.</h1>
        
      </div>

      <ColorBarcode client:load photos={photos} />
    </main>
  </body>
</html>
