---
import Base from '../../layouts/Base.astro';
import JustifiedGallery from '../../components/JustifiedGallery.jsx';
import { getFilmPhotos } from '../../lib/photos.js';

const photos = getFilmPhotos();
---

<Base title="35mm">
  <main>
    <JustifiedGallery photos={photos} targetRowHeight={300} gap={0} uniform client:load />
  </main>

  <style>
    main {
      padding: 1.5rem;
      max-width: 1600px;
      margin: 0 auto;
    }
  </style>
</Base>
