---
import PhotoLayout from '../layouts/PhotoLayout.astro';

const nav = [
  { href: '#about', label: 'About', key: 'about' },
  { href: '#projects', label: 'Projects', key: 'projects' },
  { href: '#experience', label: 'Experience', key: 'experience' },
  { href: '/photography', label: 'Photography', key: 'photography' },
  { href: '#contact', label: 'Contact', key: 'contact' }
];

const eyebrow = 'Software Engineer · New Orleans';

const intro =
  'Software engineer at Copado, working on AI platform features and agentic workflows. ' +
  'Computer science grad from Colorado College, based in New Orleans. ' +
  "When I'm not writing code, I enjoy bouldering, photography, and collaging.";

const about = [
  'I build AI tooling, full-stack web apps, and developer infrastructure, usually driven by the same habit: spotting everyday friction and shipping something genuinely useful.',
  'My background is computer science with a minor in statistics, and my thesis explored how students really use AI. I care about the craft of a clean interface as much as the system behind it.'
];

const education = {
  school: 'Colorado College',
  degree: 'B.A. Computer Science, Minor in Statistics',
  meta: 'GPA 3.89 · Dean’s List',
  thesis: 'Analysis of Artificial Intelligence Use at Colorado College',
  period: 'May 2025'
};

const skills = [
  'Python', 'Angular', 'React', 'Node.js', 'PostgreSQL', 'FastAPI', 'Docker', 'Git'
];

const projects = [
  {
    name: 'Colorado College AI Taskforce',
    blurb:
      'Full-stack analytics platform analyzing student LLM usage across 5 departments - NLP over 1,000+ queries, with an interactive dashboard for professors. My thesis project.',
    tags: ['React', 'Python', 'PostgreSQL', 'NLP'],
    href: 'https://github.com/Skingr/tigerone'
  },
  {
    name: 'Photography Portfolio',
    blurb:
      'This site - an Astro + React portfolio that indexes my film and digital work by color, sorted into an interactive barcode.',
    tags: ['Astro', 'React'],
    href: 'https://github.com/IsaacGreenwald/IsaacGreenwald.github.io'
  }
];

const experience = [
  {
    role: 'AI Software Engineer',
    org: 'Copado',
    period: 'Apr 2026 - Present',
    points: [
      "Own end-to-end design and development of a dataset-sharing feature for the company's AI platform, letting users securely share datasets with one another.",
      'Debug and improve the reliability of agentic AI workflows that deploy an AI agent in a VM to run scheduled multi-step task sequences.',
      'Ship changes across 5 large-scale repositories spanning agent frameworks and Angular UI.'
    ]
  },
  {
    role: 'Software Engineering Intern',
    org: 'Copado',
    period: 'Jan 2026 - Mar 2026',
    points: [
      'Implemented Git-based CI/CD pipelines and navigated Salesforce multi-tenant architecture alongside architect mentors.',
      'Conducted root-cause analysis in mirrored reproduction environments to resolve complex deployment errors and customer blockers.',
      'Built autonomous agents and automated testing pipelines to reduce manual development overhead.'
    ]
  },
  {
    role: 'Software Developer Intern',
    org: 'Farmhouse Chocolates',
    period: 'Dec 2025 - Jan 2026',
    points: [
      'Built a full-stack web app (React, Node.js, Firebase) to automate inventory tracking and employee task management for a local business.',
      'Assessed requirements and mapped workflows to find pain points in manual processes and design solutions.'
    ]
  },
  {
    role: 'Cybersecurity Researcher',
    org: 'NSF REU · Montana State University',
    period: 'May 2023 - Aug 2023',
    points: [
      'Evaluated the effectiveness of Snort intrusion detection against network-based attacks.',
      'Built a Docker-based client-server test environment to simulate attacks and measure detection accuracy.'
    ]
  }
];

const socials = [
  { label: 'Email', href: 'mailto:igreenwald28@gmail.com' },
  { label: 'GitHub', href: 'https://github.com/IsaacGreenwald' },
  { label: 'LinkedIn', href: 'https://www.linkedin.com/in/isaac-greenwald' },
  { label: 'Resume', href: '/resume.pdf' }
];

const ext = href => href && href.startsWith('http');
---

<PhotoLayout title="Isaac Greenwald" links={nav}>
  <main class="home">
    <section class="hero">
      <p class="eyebrow">{eyebrow}</p>
      <h1 class="display">Isaac<br />Greenwald</h1>
      <p class="intro">{intro}</p>
      <div class="links">
        {socials.map(s => (
          <a href={s.href} target={ext(s.href) ? '_blank' : undefined} rel="noopener">{s.label}</a>
        ))}
      </div>
    </section>

    <section id="about" class="block">
      <h2 class="kicker">About</h2>
      {about.map(p => <p class="prose">{p}</p>)}

      <div class="edu">
        <div class="edu-head">
          <h3>{education.school}</h3>
          <span class="edu-period">{education.period}</span>
        </div>
        <p class="edu-degree">{education.degree}</p>
        <p class="edu-meta">{education.meta}</p>
        <p class="edu-thesis"><span class="edu-thesis-label">Thesis</span> {education.thesis}</p>
      </div>

      <div class="skills">
        <p class="cluster-label">Stack</p>
        <div class="tags">
          {skills.map(s => <span class="tag">{s}</span>)}
        </div>
      </div>
    </section>

    <section id="projects" class="block">
      <h2 class="kicker">Projects</h2>
      <ul class="projects">
        {projects.map(p => {
          const Tag = p.href ? 'a' : 'div';
          return (
            <li class="project">
              <Tag class="project-link" href={p.href ?? undefined} target={ext(p.href) ? '_blank' : undefined} rel="noopener">
                <div class="project-head">
                  <h3>{p.name}</h3>
                  {p.href && <span class="arrow">↗</span>}
                </div>
                <p class="project-blurb">{p.blurb}</p>
                <div class="tags">
                  {p.tags.map(t => <span class="tag">{t}</span>)}
                </div>
              </Tag>
            </li>
          );
        })}
      </ul>
    </section>

    <section id="experience" class="block">
      <h2 class="kicker">Experience</h2>
      <ul class="experience">
        {experience.map(e => (
          <li class="exp">
            <div class="exp-period">{e.period}</div>
            <div class="exp-body">
              <h3>{e.role} <span class="exp-org">· {e.org}</span></h3>
              <ul class="exp-points">
                {e.points.map(pt => <li>{pt}</li>)}
              </ul>
            </div>
          </li>
        ))}
      </ul>
    </section>

    <section id="contact" class="block">
      <h2 class="kicker">Contact</h2>
      <p class="prose">The best way to reach me is email - otherwise find me below.</p>
      <div class="links">
        {socials.map(s => (
          <a href={s.href} target={ext(s.href) ? '_blank' : undefined} rel="noopener">{s.label}</a>
        ))}
      </div>
    </section>
  </main>

  <script>
    document.querySelectorAll('a[href^="mailto:"]').forEach(a => {
      a.addEventListener('click', async () => {
        const email = a.getAttribute('href').replace('mailto:', '');
        try {
          await navigator.clipboard.writeText(email);
          const original = a.textContent;
          a.textContent = 'Copied ✓';
          a.classList.add('copied');
          setTimeout(() => { a.textContent = original; a.classList.remove('copied'); }, 1500);
        } catch {}
      });
    });
  </script>

  <style>
    .home {
      flex: 1;
      width: 100%;
      max-width: 800px;
      margin: 0 auto;
      padding: 0 2.5rem 7rem;
      position: relative;
      z-index: 1;
    }

    /* ---------- HERO ---------- */
    .hero { padding: clamp(3rem, 14vh, 9rem) 0 5rem; }
    .eyebrow {
      font-family: var(--font-mono);
      font-size: 0.74rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--muted);
      margin-bottom: 1.5rem;
    }
    .display {
      font-family: var(--font-serif);
      font-weight: 500;
      font-size: clamp(3.2rem, 11vw, 6.5rem);
      line-height: 0.96;
      letter-spacing: -0.025em;
    }
    .intro {
      margin-top: 2.25rem;
      max-width: 36rem;
      font-size: 1.05rem;
      line-height: 1.7;
      color: #b4b4b4;
    }

    /* ---------- LINK ROWS ---------- */
    .links {
      display: flex;
      flex-wrap: wrap;
      gap: 1.75rem;
      margin-top: 2.5rem;
      font-family: var(--font-mono);
      font-size: 0.74rem;
      text-transform: uppercase;
      letter-spacing: 0.1em;
    }
    .links a {
      opacity: 0.7;
      padding-bottom: 4px;
      border-bottom: 1px solid transparent;
      transition: color 0.2s ease, border-color 0.2s ease, opacity 0.2s ease;
    }
    .links a:hover {
      opacity: 1;
      color: var(--accent);
      border-color: var(--accent);
    }
    .links a.copied {
      opacity: 1;
      color: var(--accent);
      border-color: transparent;
    }

    /* ---------- SECTIONS ---------- */
    .block {
      padding: 4.5rem 0;
      border-top: 1px solid var(--hairline);
    }
    .kicker {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.16em;
      color: var(--accent);
      font-weight: 500;
      margin-bottom: 2rem;
    }
    .prose {
      max-width: 40rem;
      font-size: 1.02rem;
      line-height: 1.75;
      color: #b4b4b4;
    }
    .prose + .prose { margin-top: 1.1rem; }

    /* ---------- EDUCATION ---------- */
    .edu {
      margin-top: 2.25rem;
      max-width: 40rem;
      background: var(--surface);
      border: 1px solid var(--hairline);
      border-left: 2px solid var(--accent);
      border-radius: 0 10px 10px 0;
      padding: 1.4rem 1.6rem;
    }
    .edu-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
    }
    .edu-period {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.08em;
      color: var(--faint);
      white-space: nowrap;
    }
    .edu h3 { font-size: 1.3rem; font-weight: 500; letter-spacing: -0.01em; }
    .edu-degree { color: #a4a4a4; font-size: 0.95rem; margin-top: 0.3rem; }
    .edu-meta {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      letter-spacing: 0.04em;
      color: var(--faint);
      margin-top: 0.5rem;
    }
    .edu-thesis {
      margin-top: 0.85rem;
      color: #d4d4d4;
      font-size: 0.95rem;
      line-height: 1.5;
    }
    .edu-thesis-label {
      font-family: var(--font-mono);
      font-size: 0.6rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--accent);
      margin-right: 0.5rem;
      vertical-align: 0.05em;
    }

    /* ---------- TAGS ---------- */
    .tags { display: flex; flex-wrap: wrap; gap: 0.5rem; }
    .skills { margin-top: 2.5rem; }
    .cluster-label {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      text-transform: uppercase;
      letter-spacing: 0.14em;
      color: var(--faint);
      margin-bottom: 0.9rem;
    }
    .tag {
      font-family: var(--font-mono);
      font-size: 0.66rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--muted);
      border: 1px solid rgba(255, 255, 255, 0.16);
      border-radius: 999px;
      padding: 0.25rem 0.65rem;
      transition: color 0.2s ease, border-color 0.2s ease, background 0.2s ease;
    }
    .tag:hover {
      color: var(--text);
      border-color: rgba(224, 162, 78, 0.5);
      background: rgba(224, 162, 78, 0.08);
    }

    /* ---------- PROJECTS ---------- */
    .projects {
      list-style: none;
      display: flex;
      flex-direction: column;
      gap: 0.85rem;
    }
    .project-link {
      display: block;
      padding: 1.5rem 1.6rem;
      background: var(--surface);
      border: 1px solid var(--hairline);
      border-radius: 10px;
      transition: transform 0.2s ease, background 0.2s ease, border-color 0.2s ease;
    }
    a.project-link:hover {
      transform: translateY(-3px);
      background: var(--surface-2);
      border-color: rgba(224, 162, 78, 0.45);
    }
    .project-head {
      display: flex;
      align-items: baseline;
      justify-content: space-between;
      gap: 1rem;
    }
    .project-head h3 {
      font-family: var(--font-serif);
      font-weight: 500;
      font-size: 1.45rem;
    }
    .arrow { color: var(--faint); transition: color 0.2s ease, transform 0.2s ease; }
    a.project-link:hover .arrow { color: var(--accent); transform: translate(2px, -2px); }
    .project-blurb {
      margin-top: 0.55rem;
      max-width: 44rem;
      color: #9a9a9a;
      font-size: 0.96rem;
      line-height: 1.6;
    }
    .project .tags { margin-top: 1rem; }

    /* ---------- EXPERIENCE ---------- */
    .experience { list-style: none; }
    .exp {
      display: grid;
      grid-template-columns: 9rem 1fr;
      gap: 1.5rem;
      padding: 1.6rem 0;
      border-bottom: 1px solid var(--hairline);
    }
    .exp:last-child { border-bottom: none; }
    .exp-period {
      font-family: var(--font-mono);
      font-size: 0.72rem;
      text-transform: uppercase;
      letter-spacing: 0.06em;
      color: var(--faint);
      padding-top: 0.3rem;
    }
    .exp-body h3 { font-size: 1.08rem; font-weight: 500; }
    .exp-org { color: var(--muted); font-weight: 400; }
    .exp-points {
      list-style: none;
      margin-top: 0.7rem;
      display: flex;
      flex-direction: column;
      gap: 0.45rem;
    }
    .exp-points li {
      position: relative;
      padding-left: 1.1rem;
      color: #9a9a9a;
      font-size: 0.93rem;
      line-height: 1.6;
    }
    .exp-points li::before {
      content: '—';
      position: absolute;
      left: 0;
      color: #555;
    }

    @media (max-width: 600px) {
      .home { padding: 0 1.4rem 4rem; }
      .exp { grid-template-columns: 1fr; gap: 0.5rem; }
    }
  </style>
</PhotoLayout>
